# 백엔드 API 호출 베이스. 환경별로 도메인+prefix 통째로 지정한다.
# - 로컬 dev (vite dev + 로컬 서버):  http://localhost:8080
# - prod (학교 ingress 가 /festival/api 를 strip 하여 백엔드 root 로 전달): https://chcse.knu.ac.kr/festival/api
VITE_API_BASE_URL=http://localhost:8080

# axios 요청 타임아웃 (ms)
VITE_API_TIMEOUT_MS=10000

# Sentry (에러 트래킹) — 프로덕션 배포 시에만 설정
VITE_SENTRY_DSN=
VITE_SENTRY_ORG=
VITE_SENTRY_PROJECT=knu-festival-80th-client
SENTRY_AUTH_TOKEN=

# PostHog (제품 분석) — 키가 비어 있으면 Provider 가 자동으로 비활성화
VITE_PUBLIC_POSTHOG_KEY=
VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Google Analytics 4 (선택)
VITE_GA_ID=

# Microsoft Clarity (사용자 행동 녹화 및 히트맵) — 비어 있으면 비활성화
VITE_CLARITY_ID=
